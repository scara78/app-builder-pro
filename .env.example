# =============================================================================
# Environment Variables Configuration
# =============================================================================
# Copiá este archivo como .env y completá los valores necesarios.
# NUNCA commitees .env a git — ya está en .gitignore

# -----------------------------------------------------------------------------
# Google AI (Gemini) API Configuration
# -----------------------------------------------------------------------------
# OBTENER API KEY:
# 1. Andá a https://aistudio.google.com/app/apikey
# 2. Creá una nueva API key
# 3. Copiá la key aquí
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# OBTENER CONFIGURACIÓN:
# 1. Andá a https://supabase.com/dashboard
# 2. Seleccioná tu proyecto → Settings → API
# 3. Copiá "Project URL" a VITE_SUPABASE_URL
# 4. Copiá "anon public" key a VITE_SUPABASE_ANON_KEY

# URL del proyecto (formato: https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon key (public - es seguros incluirlo en cliente)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# -----------------------------------------------------------------------------
# MCP Configuration (Opcional)
# -----------------------------------------------------------------------------
# Solo necesario si usás el servidor MCP para operaciones de gestión
# OBTENER TOKEN:
# 1. Andá a https://supabase.com/dashboard/settings/api
# 2. En "Project API Keys", copy "access token"
#SUPABASE_ACCESS_TOKEN=your-oauth-token-here
